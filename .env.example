# ============================================================
#  clinic-patient-service — variables de entorno
#  Copiar a .env y completar los valores
# ============================================================

PORT=3003
NODE_ENV=development

# ---- BD propia del patient-service -------------------------
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USERNAME=patient_svc_user
DB_PASSWORD=changeme
DB_NAME=patient_db
DB_SSL=false

# ---- URL del user-service (HTTP REST) ----------------------
# En K8s usa el nombre del Service interno
# En dev local usa la IP/puerto directo
USER_SERVICE_URL=http://localhost:3002

# ---- CORS --------------------------------------------------
ALLOWED_ORIGINS=http://localhost:4200

# ---- Swagger -----------------------------------------------
SWAGGER_USER=admin
SWAGGER_PASSWORD=changeme
